{
  "name": "contratacion-servicio-mvp",
  "version": "1.0.0",
  "private": true,
  "description": "Módulo de Contratación de Servicio - Marketplace de trabajos cortos (Grupo 5)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "cd apps/backend && npm run start:dev",
    "backend:build": "cd apps/backend && npm run build",
    "backend:test": "cd apps/backend && npm run test",
    "frontend:dev": "cd apps/frontend && npm run dev",
    "frontend:build": "cd apps/frontend && npm run build",
    "frontend:test": "cd apps/frontend && npm run test",
    "db:migrate": "cd apps/backend && npx prisma migrate dev",
    "db:generate": "cd apps/backend && npx prisma generate",
    "db:studio": "cd apps/backend && npx prisma studio",
    "install:all": "npm install && cd apps/backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "clean": "rimraf node_modules apps/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/grupo5/contratacion-servicio-mvp"
  },
  "keywords": [
    "marketplace",
    "nestjs",
    "react",
    "typescript",
    "prisma",
    "design-patterns"
  ],
  "author": "Grupo 5",
  "license": "MIT"
}
